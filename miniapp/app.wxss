/* ========================================
   学习打卡追踪器 - 全局样式
   设计语言：羊皮纸暖色调 + 赤陶主色
   极致还原原型设计
   ======================================== */

/* 全局盒模型 */
view, text, scroll-view, button, input, textarea, navigator, image, canvas, picker, swiper, swiper-item {
  box-sizing: border-box;
}

page {
  --parchment: #f5f4ed;
  --ivory: #faf9f5;
  --white: #fff;
  --sand: #e8e6dc;
  --sand-soft: #f0eee6;
  --border: #e8e6dc;
  --cream: #f0eee6;
  --black: #141413;
  --dark: #30302e;
  --charcoal: #4d4c48;
  --olive: #5e5d59;
  --stone: #87867f;
  --silver: #b0aea5;
  --terracotta: #c96442;
  --sage: #6f735f;
  --sage-soft: #ecebe1;
  --clay-soft: #f1e3dc;
  --ink-soft: #e2e0d6;
  --ring: #d1cfc5;
  --error: #b53333;
  --focus: #3898ec;
  --serif: Georgia, "Times New Roman", serif;
  --sans: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;

  background:
    radial-gradient(circle at 20% 12%, rgba(201,100,66,.08), transparent 34%),
    linear-gradient(135deg, #ebe7dc, #f5f4ed 48%, #dedbd0);
  font-family: var(--sans);
  color: var(--black);
  -webkit-font-smoothing: antialiased;
  font-size: 15px;
  line-height: 1.6;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* --- 自定义导航栏 --- */
.nav-bar {
  height: 70px;
  padding: 24px 14px 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1px solid rgba(232,230,220,.72);
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(245,244,237,.94);
  backdrop-filter: blur(18px);
}

.nav-content {
  width: 100%;
  height: 46px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 17px;
  font-weight: 600;
}

/* --- 页面容器 --- */
.screen {
  padding: 18px 18px 96px;
  overflow-y: auto;
  width: 100%;
  max-width: 100vw;
}

/* nav-bar 固定在顶部时，联动修复 */
.nav-bar {
  width: 100%;
  max-width: 100vw;
}

/* --- 页面引导文案 --- */
.page-kicker {
  font-size: 12px;
  color: var(--stone);
  letter-spacing: .05em;
  margin: 2px 0 6px;
}

.page-title {
  font-family: var(--serif);
  font-size: 31px;
  line-height: 1.14;
  font-weight: 500;
  margin: 0;
}

.page-subtitle {
  margin: 9px 0 0;
  color: var(--olive);
  font-size: 15px;
  line-height: 1.55;
}

/* --- 卡片 --- */
.card {
  background: var(--ivory);
  border: 1px solid var(--cream);
  border-radius: 18px;
  box-shadow: 0 4px 24px rgba(20,20,19,.06);
}

.pad {
  padding: 18px;
}

.mt {
  margin-top: 18px;
}

.mt14 {
  margin-top: 14px;
}

/* --- 区域标题 --- */
.section-title {
  font-family: var(--serif);
  font-size: 23px;
  font-weight: 500;
  margin: 0 0 12px;
}

/* --- 标签 --- */
.tag {
  min-height: 28px;
  display: inline-flex;
  align-items: center;
  padding: 0 10px;
  border-radius: 999px;
  background: var(--sand);
  color: var(--charcoal);
  font-size: 12px;
  box-shadow: 0 0 0 1px var(--ring);
  white-space: nowrap;
}

.tag.clay {
  background: var(--clay-soft);
  color: var(--terracotta);
  box-shadow: 0 0 0 1px rgba(201,100,66,.2);
}

.tag.sage {
  background: var(--sage-soft);
  color: var(--sage);
  box-shadow: 0 0 0 1px rgba(111,115,95,.2);
}

.tag.ink {
  background: var(--black);
  color: var(--ivory);
  box-shadow: inset 0 0 0 1px var(--dark);
}

.tag.quiet {
  background: var(--sand-soft);
  color: var(--stone);
}

/* --- 按钮 --- */
.primary, .secondary, .dark {
  min-height: 46px;
  border-radius: 14px;
  padding: 0 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 0;
  font-size: 15px;
}

.primary {
  background: var(--terracotta);
  color: var(--ivory);
}

.secondary {
  background: var(--sand);
  color: var(--charcoal);
  box-shadow: 0 0 0 1px var(--ring);
}

.dark {
  background: var(--black);
  color: var(--ivory);
}

/* --- 分段控制器 --- */
.segmented {
  display: flex;
  gap: 5px;
  padding: 5px;
  border-radius: 999px;
  background: var(--sand);
  box-shadow: 0 0 0 1px var(--ring);
  margin-top: 18px;
}

.segmented.two .seg-btn {
  flex: 1;
}

.seg-btn {
  flex: 1;
  min-height: 36px;
  border-radius: 999px;
  background: transparent;
  color: var(--olive);
  font-size: 13px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 0;
}

.seg-btn.active {
  background: var(--ivory);
  color: var(--black);
  box-shadow: 0 2px 12px rgba(20,20,19,.08);
}

/* --- 底部弹层 --- */
.sheet-overlay {
  position: fixed;
  inset: 0;
  background: rgba(20,20,19,.34);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.sheet-panel {
  width: 100%;
  background: var(--ivory);
  border-radius: 26px 26px 0 0;
  padding: 12px 18px 28px;
  box-shadow: 0 -16px 48px rgba(20,20,19,.18);
}

.grabber {
  width: 42px;
  height: 5px;
  background: var(--ring);
  border-radius: 999px;
  margin: 0 auto 18px;
}

.sheet-panel .sheet-title {
  margin: 0;
  font-family: var(--serif);
  font-size: 25px;
  font-weight: 500;
}

.sheet-panel .sheet-desc {
  color: var(--olive);
  line-height: 1.55;
  margin: 8px 0 16px;
}

/* --- Toast --- */
.toast {
  position: fixed;
  left: 24px;
  right: 24px;
  bottom: 96px;
  min-height: 44px;
  border-radius: 16px;
  background: rgba(20,20,19,.92);
  color: var(--ivory);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  z-index: 2000;
  opacity: 0;
  pointer-events: none;
  transition: opacity .22s;
}

.toast.show {
  opacity: 1;
}

/* --- Flex 工具 --- */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

.gap-10 {
  gap: 10px;
}

.gap-12 {
  gap: 12px;
}

.gap-14 {
  gap: 14px;
}

/* --- 分割线 --- */
.divider-line {
  height: 1px;
  background: var(--cream);
  margin: 10px 0;
}

/* --- 空状态 --- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 18px;
  color: var(--stone);
}

.empty-state .empty-title {
  font-family: var(--serif);
  font-size: 17px;
  color: var(--olive);
  margin-top: 12px;
}

.empty-state .empty-desc {
  font-size: 14px;
  text-align: center;
  line-height: 1.5;
  margin-top: 6px;
}

/* --- 开关 --- */
.switch-wrap {
  width: 52px;
  height: 32px;
  padding: 3px;
  border-radius: 999px;
  background: var(--sand);
  box-shadow: inset 0 0 0 1px var(--ring);
  transition: .18s;
}

.switch-wrap.on {
  background: var(--terracotta);
}

.switch-wrap .switch-thumb {
  display: block;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: var(--white);
  box-shadow: 0 2px 8px rgba(20,20,19,.16);
  transition: .18s;
}

.switch-wrap.on .switch-thumb {
  transform: translateX(20px);
}

.text-muted {
  color: var(--stone);
  font-size: 13px;
}

.text-primary {
  color: var(--terracotta);
  font-weight: 600;
}

.text-danger {
  color: var(--error);
}
