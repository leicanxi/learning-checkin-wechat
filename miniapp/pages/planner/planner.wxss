/* 规划页样式 */

/* 模式选择与输入 */
.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.field-label {
  color: var(--stone);
  font-size: 12px;
}

.mode-picker {
  display: flex;
  align-items: center;
  gap: 4px;
  height: 32px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: var(--sand-soft);
  color: var(--charcoal);
  font-size: 12px;
  padding: 0 9px;
}

.mode-arrow {
  font-size: 10px;
  color: var(--stone);
  margin-left: 4px;
}

.goal-input {
  width: 100%;
  min-height: 104px;
  border: 1px solid var(--border);
  background: var(--white);
  border-radius: 16px;
  padding: 13px 14px;
  color: var(--black);
  line-height: 1.5;
  font-size: 14px;
  box-sizing: border-box;
}

.planner-actions {
  display: flex;
  gap: 10px;
  margin-top: 12px;
}

.icon-action {
  width: 46px;
  min-width: 46px;
  height: 46px;
  border-radius: 14px;
  background: var(--sand);
  color: var(--charcoal);
  box-shadow: 0 0 0 1px var(--ring);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 18px;
}

.icon-action.recording {
  background: var(--clay-soft);
  color: var(--terracotta);
}

.icon-action.processing {
  background: var(--clay-soft);
  color: var(--stone);
  animation: voice-pulse 1.2s ease-in-out infinite;
}

@keyframes voice-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* 自定义计划 */
.custom-grid {
  display: flex;
  gap: 8px;
}

.custom-input {
  flex: 1;
  min-height: 42px;
  border-radius: 13px;
  border: 1px solid var(--border);
  background: var(--white);
  font-size: 13px;
  padding: 10px 12px;
  color: var(--black);
  box-sizing: border-box;
}

.repeat-box {
  margin-top: 10px;
  padding: 10px;
  border-radius: 14px;
  background: var(--ivory);
  border: 1px solid var(--cream);
}

.everyday-btn {
  min-height: 30px;
  padding: 0 10px;
  border-radius: 999px;
  background: var(--sand);
  color: var(--charcoal);
  box-shadow: 0 0 0 1px var(--ring);
  font-size: 12px;
  font-weight: 600;
  display: flex;
  align-items: center;
}

.everyday-active {
  background: var(--black);
  color: var(--ivory);
  box-shadow: inset 0 0 0 1px var(--dark);
}

.weekday-grid {
  display: flex;
  gap: 6px;
}

.weekday-btn {
  flex: 1;
  min-height: 32px;
  border-radius: 999px;
  background: var(--sand-soft);
  color: var(--olive);
  box-shadow: 0 0 0 1px var(--border);
  font-size: 12px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.weekday-active {
  background: var(--clay-soft);
  color: var(--terracotta);
  box-shadow: 0 0 0 1px rgba(201,100,66,.24);
}

/* 生成列表 */
.generated-task {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px;
  border: 1px solid var(--cream);
  border-radius: 14px;
  background: var(--white);
  margin-bottom: 10px;
}

.step-no {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: var(--terracotta);
  color: var(--ivory);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  flex-shrink: 0;
}

.gen-task-name {
  flex: 1;
  color: var(--olive);
  font-size: 14px;
  line-height: 1.45;
}

.icon-btn {
  width: 28px;
  height: 28px;
  border-radius: 9px;
  background: var(--sand);
  color: var(--charcoal);
  box-shadow: 0 0 0 1px var(--ring);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
}
