/* 统计页样式 */

.chart-canvas {
  display: block;
}

.bar-fallback {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-around;
  height: 160px;
  padding-top: 24px;
}

.bar-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.bar-val {
  font-size: 10px;
  font-weight: 600;
  color: var(--terracotta);
  margin-bottom: 4px;
}

.bar {
  width: 24px;
  border-radius: 6px 6px 0 0;
  background: linear-gradient(180deg, var(--terracotta), #d48364);
  min-height: 4px;
}

.bar-label {
  font-size: 10px;
  color: var(--stone);
  margin-top: 6px;
}

/* 环形进度 */
.ring-grid {
  display: flex;
  gap: 12px;
  margin-top: 14px;
}

.ring-card {
  flex: 1;
  padding: 15px;
  border-radius: 18px;
  background: var(--ivory);
  border: 1px solid var(--cream);
  display: flex;
  gap: 12px;
  align-items: center;
}

.progress-ring {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.progress-ring .ring-inner {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--ivory);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 18px;
  font-weight: 500;
}

.ring-subject {
  font-size: 14px;
  font-weight: 600;
  display: block;
}

.ring-note {
  color: var(--olive);
  font-size: 12px;
  display: block;
  margin-top: 2px;
}

/* 累计完成打卡 */
.completion-card {
  padding: 16px;
  border-radius: 18px;
  background: var(--black);
  color: var(--ivory);
  margin-top: 14px;
}

.completion-label {
  font-size: 12px;
  color: var(--silver);
  padding: 4px 10px;
  border-radius: 999px;
  background: var(--dark);
  display: inline-block;
}

.completion-num {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 42px;
  font-weight: 500;
  margin-top: 8px;
  line-height: 1;
  display: block;
}

.completion-desc {
  color: var(--silver);
  font-size: 13px;
  line-height: 1.45;
  margin: 8px 0 0;
  display: block;
}

/* 科目分布 */
.subject-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.subject-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.subject-name {
  font-size: 13px;
  color: var(--olive);
  width: 48px;
  flex-shrink: 0;
}

.track {
  flex: 1;
  height: 9px;
  border-radius: 999px;
  background: var(--sand);
  overflow: hidden;
}

.fill {
  height: 100%;
  border-radius: 999px;
  background: var(--terracotta);
}

.subject-val {
  font-size: 12px;
  color: var(--olive);
  width: 36px;
  text-align: right;
  flex-shrink: 0;
}

/* 排名 Hero */
.rank-hero {
  padding: 18px;
  border-radius: 24px;
  background: var(--black);
  color: var(--ivory);
  position: relative;
  overflow: hidden;
}

.rank-hero::after {
  content: "";
  position: absolute;
  width: 120px;
  height: 120px;
  right: -42px;
  bottom: -48px;
  border-radius: 50%;
  border: 1px solid rgba(217,119,87,.42);
}

.rank-label-row {
  display: flex;
  align-items: center;
  gap: 6px;
  position: relative;
  z-index: 1;
}

.rank-scope-label {
  color: var(--silver);
  font-size: 12px;
}

.info-btn {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--dark);
  color: var(--silver);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 700;
  box-shadow: inset 0 0 0 1px rgba(255,255,255,.05);
}

.rank-percent {
  display: block;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 42px;
  font-weight: 500;
  margin: 8px 0;
  position: relative;
  z-index: 1;
}

.rank-honor {
  margin: 0;
  color: var(--silver);
  font-size: 13px;
  line-height: 1.5;
  position: relative;
  z-index: 1;
  display: block;
}

/* 徽章墙 */
.badge-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 12px;
}

.badge-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.badge-item {
  width: calc((100% - 20px) / 3);
  min-height: 82px;
  padding: 12px 8px;
  border-radius: 16px;
  background: var(--ivory);
  border: 1px solid var(--cream);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.badge-icon {
  width: 30px;
  height: 30px;
  margin: 0 auto 8px;
  border-radius: 12px;
  background: var(--clay-soft);
  color: var(--terracotta);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.badge-name {
  font-size: 12px;
  color: var(--charcoal);
  line-height: 1.3;
}

/* Sheet 列表项 */
.sheet-list {
  margin: 14px 0 16px;
}

.sheet-item {
  padding: 12px;
  border-radius: 14px;
  background: var(--sand-soft);
  border: 1px solid var(--border);
  margin-bottom: 10px;
}

.sheet-item-title {
  display: block;
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 4px;
}

.sheet-item-desc {
  color: var(--olive);
  font-size: 12px;
  line-height: 1.4;
}
