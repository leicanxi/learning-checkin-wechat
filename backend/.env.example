# ===========================================
# 学习打卡追踪器 - 环境变量配置
# ===========================================
# 复制此文件为 .env 并修改为你的实际配置

# 数据库配置
DATABASE_URL=sqlite:///./learning_tracker.db

# JWT 认证配置
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 微信小程序配置
WECHAT_APPID=wx_test_appid
WECHAT_APPSECRET=test_appsecret

# 微信订阅消息模板 ID（在微信公众平台后台 -> 订阅消息 -> 选用模板后，把模板ID填到这里）
WECHAT_TMPL_DAILY_CHECKIN=
WECHAT_TMPL_TASK_DEADLINE=

# DeepSeek AI 配置
DEEPSEEK_API_KEY=sk-test-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 腾讯云 ASR (语音识别) 配置
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# 文件上传目录
UPLOAD_DIR=./uploads
